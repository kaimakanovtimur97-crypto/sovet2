# Скопируйте этот файл в .env.local (для локального запуска)
# и продублируйте те же переменные в настройках Vercel:
# Project → Settings → Environment Variables

# API-ключ Resend (https://resend.com → API Keys). Бесплатно: 3000 писем/мес.
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxx

# Почта, на которую приходят заявки с форм
LEAD_TO_EMAIL=you@example.com

# Отправитель. Для теста подойдёт значение по умолчанию (onboarding@resend.dev),
# но письма будут уходить ТОЛЬКО на почту владельца аккаунта Resend.
# Когда подтвердите свой домен в Resend — поставьте адрес на нём, например:
# LEAD_FROM_EMAIL=Заявки с сайта <noreply@ваш-домен.ru>
LEAD_FROM_EMAIL=Заявки с сайта <onboarding@resend.dev>

# --- Telegram (опционально, можно вместе с email) ---
# 1. Напишите @BotFather в Telegram → /newbot → получите токен вида 123456:AA...
# 2. Напишите своему новому боту любое сообщение (например /start)
# 3. Откройте в браузере https://api.telegram.org/bot<ВАШ_ТОКЕН>/getUpdates
#    и найдите "chat":{"id": ЧИСЛО, ...} — это ваш chat_id
TELEGRAM_BOT_TOKEN=123456789:AAxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TELEGRAM_CHAT_ID=123456789
